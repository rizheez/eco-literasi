{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "eco-dayak-kids",
  "version": "0.1.0",
  "identifier": "com.ecodayakkids.game",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "ECO-DAYAK Kids",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self' data: asset:; connect-src 'self' ws: wss: http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
